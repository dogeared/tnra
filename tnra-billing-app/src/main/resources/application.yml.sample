# Sample base config for tnra-billing-app (the central billing service).
#
# application.yml itself is gitignored (repo `*.yml` rule), so each environment keeps a local copy:
#   cp tnra-billing-app/src/main/resources/application.yml.sample \
#      tnra-billing-app/src/main/resources/application.yml
#
# This service is a CENTRAL single instance (not run per-group, not run by self-hosters). Production
# overrides the datasource and the PADDLE_* / billing secrets via env in docker-compose.production.yml.
spring:
  jpa:
    hibernate:
      ddl-auto: validate
  datasource:
    url: jdbc:mysql://localhost:3307/tnra_billing?useSSL=false&allowPublicKeyRetrieval=true
    username: tnra
    password: 123456aA$
  flyway:
    baseline-on-migrate: true
    baseline-version: 0
    locations: classpath:db/migration

server:
  port: 8082
  forward-headers-strategy: framework

# Paddle (Merchant of Record). All blank by default; required in production.
paddle:
  api-key: ${PADDLE_API_KEY:}
  # Defaults to Paddle sandbox; set https://api.paddle.com for live.
  api-base: ${PADDLE_API_BASE:https://sandbox-api.paddle.com}
  # Notification destination secret key (pdl_ntfset_...).
  webhook-secret: ${PADDLE_WEBHOOK_SECRET:}
  price:
    monthly: ${PADDLE_PRICE_MONTHLY:}   # $7 / month / member  (Paddle Price id)
    yearly: ${PADDLE_PRICE_YEARLY:}     # $60 / year / member  (Paddle Price id)

billing:
  # Default free-trial window applied to a new group at provisioning (group_billing.comp_until).
  trial-days: ${TNRA_TRIAL_DAYS:60}
  # Shared secret guarding the provisioning/admin API (/api/admin/**). Blank = admin API disabled
  # (fail closed). The CLI sends it as X-Admin-Token when registering a group.
  admin-token: ${BILLING_ADMIN_TOKEN:}

logging:
  level:
    com.afitnerd.tnra.billing: INFO
    org.springframework.security: WARN
