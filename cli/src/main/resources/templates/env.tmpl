# Generated by tnra-cli for group: {{GROUP_NAME}}
# Date: {{DATE}}
#
# For local IDE development only — not loaded by the production docker-compose.
# IDE tools (IntelliJ, VS Code) can use this file to connect to the host-mapped ports.

# --- Database ---
SPRING_DATASOURCE_USERNAME={{DB_USER}}
SPRING_DATASOURCE_PASSWORD={{DB_PASSWORD}}
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/{{DB_NAME}}
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=1
SPRING_JPA_HIBERNATE_DDL-AUTO=validate

# --- Keycloak ---
KEYCLOAK_CLIENT_ID={{GROUP_NAME}}-app
KEYCLOAK_CLIENT_SECRET={{KEYCLOAK_CLIENT_SECRET}}
KEYCLOAK_ISSUER_URI=https://auth.{{DOMAIN}}/realms/{{REALM_NAME}}

# --- Encryption ---
# WARNING: copy this value from TNRA_ENCRYPTION_MASTER_KEY in your production .env — never change it after first startup
TNRA_ENCRYPTION_MASTER_KEY=

# --- App ---
SERVER_FORWARD_HEADERS_STRATEGY=framework
VAADIN_PRODUCTIONMODE=true
TNRA_NOTIFY_SCHEDULE=0 0 12 * * ?

# --- Email (optional) ---
MAILGUN_KEY_PRIVATE=
MAILGUN_KEY_PUBLIC=
MAILGUN_URL=
