services:
  tnra-{{GROUP_NAME}}:
    container_name: tnra-{{GROUP_NAME}}
    image: tnra
    build:
      context: .
      dockerfile: Dockerfile
    env_file:
      - .env
    environment:
      KEYCLOAK_ISSUER_URI: http://keycloak:8080/realms/{{REALM_NAME}}
      SPRING_DATASOURCE_URL: jdbc:mysql://mysql:3306/{{DB_NAME}}
      SPRING_FLYWAY_BASELINE_ON_MIGRATE: "true"
      SPRING_FLYWAY_BASELINE_VERSION: 1
      SPRING_JPA_HIBERNATE_DDL-AUTO: validate
      VAADIN_PRODUCTIONMODE: "true"
    volumes:
      - ./uploads/{{GROUP_NAME}}:/uploads:rw
    networks:
      - tnra-shared

networks:
  tnra-shared:
    external: true
    name: tnra-shared
