services:
  tnra-{{GROUP_NAME}}:
    container_name: tnra-{{GROUP_NAME}}
    image: tnra
    build:
      context: ../..
      dockerfile: Dockerfile
    env_file:
      - {{GROUP_NAME}}/.env
    environment:
      SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_KEYCLOAK_TOKEN_URI: http://keycloak:8080/realms/{{REALM_NAME}}/protocol/openid-connect/token
      SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_KEYCLOAK_USER_INFO_URI: http://keycloak:8080/realms/{{REALM_NAME}}/protocol/openid-connect/userinfo
      SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_KEYCLOAK_JWK_SET_URI: http://keycloak:8080/realms/{{REALM_NAME}}/protocol/openid-connect/certs
    volumes:
      - ./uploads/{{GROUP_NAME}}:/uploads:rw
    networks:
      - tnra-production-shared

networks:
  tnra-production-shared:
    external: true
    name: tnra-production-shared
